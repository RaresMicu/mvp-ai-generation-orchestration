    {
        "id": "example_parallel_merge",
        "description": "Diamond Pattern. Fetch user, run fraud check and social enrichment in parallel, then log the results once both complete.",
        "json": {
            "workflow": {
                "name": "parallel_verification_flow",
                "entrypoint": "fetch_user",
                "activities": [
                    {
                        "id": "fetch_user",
                        "type": "http_call",
                        "method": "GET",
                        "endpoint": "/users/{id}",
                        "parallel_group": null,
                        "retry_policy": {
                            "maximum_attempts": 3,
                            "initial_interval_seconds": 5
                        },
                        "timeout_seconds": 30
                    },
                    {
                        "id": "fraud_check",
                        "type": "http_call",
                        "method": "GET",
                        "endpoint": "/fraud/{id}",
                        "parallel_group": "g1",
                        "retry_policy": {
                            "maximum_attempts": 3,
                            "initial_interval_seconds": 5
                        },
                        "timeout_seconds": 30
                    },
                    {
                        "id": "social_enrichment",
                        "type": "http_call",
                        "method": "POST",
                        "endpoint": "/enrich/{id}",
                        "parallel_group": "g1",
                        "retry_policy": {
                            "maximum_attempts": 3,
                            "initial_interval_seconds": 5
                        },
                        "timeout_seconds": 30
                    },
                    {
                        "id": "system_audit",
                        "type": "http_call",
                        "method": "POST",
                        "endpoint": "/audit",
                        "parallel_group": null,
                        "retry_policy": {
                            "maximum_attempts": 3,
                            "initial_interval_seconds": 5
                        },
                        "timeout_seconds": 30
                    }
                ],
                "dependencies": [
                    {
                        "from": "fetch_user",
                        "to": "fraud_check",
                        "condition": "success"
                    },
                    {
                        "from": "fetch_user",
                        "to": "social_enrichment",
                        "condition": "success"
                    },
                    {
                        "from": "fraud_check",
                        "to": "system_audit",
                        "condition": "success"
                    },
                    {
                        "from": "social_enrichment",
                        "to": "system_audit",
                        "condition": "success"
                    }
                ]
            }
        }
    },
    {
        "id": "example_failure_handling",
        "description": "Failure Handling. Fetch user data, then run fraud check. If the fraud check fails, escalate to manual review. On success, log the audit.",
        "json": {
            "workflow": {
                "name": "failure_handling_flow",
                "entrypoint": "fetch_user",
                "activities": [
                    {
                        "id": "fetch_user",
                        "type": "http_call",
                        "method": "GET",
                        "endpoint": "/users/{id}",
                        "parallel_group": null,
                        "retry_policy": {
                            "maximum_attempts": 3,
                            "initial_interval_seconds": 5
                        },
                        "timeout_seconds": 30
                    },
                    {
                        "id": "fraud_check",
                        "type": "http_call",
                        "method": "GET",
                        "endpoint": "/fraud/{id}",
                        "parallel_group": null,
                        "retry_policy": {
                            "maximum_attempts": 3,
                            "initial_interval_seconds": 5
                        },
                        "timeout_seconds": 30
                    },
                    {
                        "id": "system_audit",
                        "type": "http_call",
                        "method": "POST",
                        "endpoint": "/audit",
                        "parallel_group": null,
                        "retry_policy": {
                            "maximum_attempts": 3,
                            "initial_interval_seconds": 5
                        },
                        "timeout_seconds": 30
                    },
                    {
                        "id": "manual_review",
                        "type": "http_call",
                        "method": "POST",
                        "endpoint": "/review",
                        "parallel_group": null,
                        "retry_policy": {
                            "maximum_attempts": 3,
                            "initial_interval_seconds": 5
                        },
                        "timeout_seconds": 30
                    }
                ],
                "dependencies": [
                    {
                        "from": "fetch_user",
                        "to": "fraud_check",
                        "condition": "success"
                    },
                    {
                        "from": "fraud_check",
                        "to": "system_audit",
                        "condition": "success"
                    },
                    {
                        "from": "fraud_check",
                        "to": "manual_review",
                        "condition": "failure"
                    }
                ]
            }
        }
    }
]