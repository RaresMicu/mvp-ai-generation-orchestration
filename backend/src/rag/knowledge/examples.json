[
    {
        "id": "example_onboarding",
        "description": "User Onboarding Flow. Fetch user data, then enrich their profile with social data.",
        "json": {
            "workflow": {
                "name": "user_onboarding",
                "entrypoint": "fetch_user",
                "activities": [
                    {
                        "id": "fetch_user",
                        "type": "http_call",
                        "method": "GET",
                        "endpoint": "/users/{id}",
                        "parallel_group": null,
                        "retry_policy": {
                            "maximum_attempts": 3,
                            "initial_interval_seconds": 5
                        },
                        "timeout_seconds": 30
                    },
                    {
                        "id": "social_enrichment",
                        "type": "http_call",
                        "method": "POST",
                        "endpoint": "/enrich/{id}",
                        "parallel_group": null,
                        "retry_policy": {
                            "maximum_attempts": 3,
                            "initial_interval_seconds": 5
                        },
                        "timeout_seconds": 30
                    }
                ],
                "dependencies": [
                    {
                        "from": "fetch_user",
                        "to": "social_enrichment",
                        "condition": "success"
                    }
                ]
            }
        }
    },
    {
